rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /** Spójny odczyt roli (unika błędów gdy pole role nie istnieje). */
    function requestUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function requestUserRole() {
      return requestUserData().get('role', '');
    }
    /**
     * Zgodnie z useAuth (trim + case): sama funkcja .lower() w regułach nie usuwa spacji —
     * pole role == "admin " lub " admin" przechodziło w UI, a blokowało zapisy (permission-denied).
     */
    function isAdminRoleString(r) {
      return r is string && r.size() > 0 && r.lower().matches('^\\s*admin\\s*$');
    }
    /** Admin z JWT (Admin SDK) lub rola w users — bez rozróżniania wielkości liter (np. „Admin”). */
    function isRequestAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          isAdminRoleString(requestUserData().get('role', ''))
        )
      );
    }
    /** Legacy: allowedTeams czasem zapisane jako jeden string zamiast listy — hasAny / in muszą to obsłużyć. */
    function teamIdInAllowedTeams(teamId, userData) {
      let a = userData.get('allowedTeams', []);
      return teamId.size() > 0 &&
        ((a is list && teamId in a) || (a is string && a.size() > 0 && teamId == a));
    }

    function isPlayerRoleField(r) {
      return r is string && r.size() > 0 && r.lower().matches('^\\s*player\\s*$');
    }

    /** Brak przypisanych zespołów: pusta lista, null, pusty string lub pole nieustawione (get zwraca []). */
    function allowedTeamsEffectivelyEmpty() {
      let a = requestUserData().get('allowedTeams', []);
      return a == null ||
        (a is list && a.size() == 0) ||
        (a is string && a.size() == 0);
    }

    /**
     * Sztab (wszystko poza player): brak skonfigurowanej allowedTeams — może dodać mecz z dowolnym niepustym team.
     * Gdy allowedTeams ma wpisy (lista lub niepusty string), obowiązuje teamIdInAllowedTeams.
     */
    function staffWithNoTeamListCanCreateMatch() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        request.resource.data.get('team', '').size() > 0 &&
        allowedTeamsEffectivelyEmpty() &&
        !isPlayerRoleField(requestUserData().get('role', ''));
    }

    /** Zalogowany bez dokumentu users/{uid} (np. pierwszy login przed udanym zapisem profilu). */
    function authenticatedWithoutUserDocCanWriteMatch() {
      return !exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        request.resource.data.get('team', '').size() > 0;
    }

    /** Czy pole teams zawodnika (lista lub string) przecina się z allowedTeams użytkownika (lista lub string). */
    function teamsTouchAllowed(t, allowed) {
      return (t is list && allowed is list && t.hasAny(allowed)) ||
        (t is list && allowed is string && allowed.size() > 0 && allowed in t) ||
        (t is string && allowed is list && t.size() > 0 && t in allowed) ||
        (t is string && allowed is string && t.size() > 0 && allowed.size() > 0 && t == allowed);
    }

    /** Legacy: teams (lista|string), team oraz teamId (część dokumentów ma tylko teamId — UI to scala, reguły muszą też). */
    function teamsDataTouchesAllowed(data) {
      let allowed = requestUserData().get('allowedTeams', []);
      let t = data.get('teams', null);
      let leg = data.get('team', null);
      let tid = data.get('teamId', null);
      return teamsTouchAllowed(t, allowed) ||
        (leg is string && leg.size() > 0 && teamsTouchAllowed(leg, allowed)) ||
        (tid is string && tid.size() > 0 && teamsTouchAllowed(tid, allowed));
    }

    /** Nowa wartość teams ⊆ stara (usuwanie zespołów / migracja listy); list|string + legacy team + legacy teamId. */
    function normalizedTeamsHasOnlySubset(oldData, newData) {
      let o = oldData.get('teams', null);
      let oLeg = oldData.get('team', null);
      let oTid = oldData.get('teamId', null);
      let n = newData.get('teams', null);
      return (o is list && n is list && n.hasOnly(o)) ||
        (o is list && n is string && n.size() > 0 && n in o) ||
        (o is string && o.size() > 0 && n is list && (n.size() == 0 || (n.size() == 1 && n[0] == o))) ||
        (o is string && o.size() > 0 && n is string && n == o) ||
        (
          o == null &&
          oLeg is string && oLeg.size() > 0 &&
          n is list &&
          (n.size() == 0 || (n.size() == 1 && n[0] == oLeg))
        ) ||
        (
          o is list && o.size() == 0 &&
          oLeg is string && oLeg.size() > 0 &&
          n is list &&
          (n.size() == 0 || (n.size() == 1 && n[0] == oLeg))
        ) ||
        (
          o == null &&
          oLeg == null &&
          oTid is string && oTid.size() > 0 &&
          n is list &&
          (n.size() == 0 || (n.size() == 1 && n[0] == oTid))
        ) ||
        (
          o is list && o.size() == 0 &&
          oLeg == null &&
          oTid is string && oTid.size() > 0 &&
          n is list &&
          (n.size() == 0 || (n.size() == 1 && n[0] == oTid))
        );
    }

    function hasForbiddenPIIKeys(data) {
      return data.keys().hasAny([
        "firstName",
        "lastName",
        "name",
        "birthYear",
        "number",
        "playerName",
        "senderName",
        "receiverName",
        "assistantName",
        "senderNumber",
        "receiverNumber"
      ]);
    }

    // Domyślnie tylko odczyt
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Kolekcja użytkowników - tylko właściciel i admini
    match /users/{userId} {
      allow read, write: if request.auth != null &&
        (request.auth.uid == userId || isRequestAdmin());
    }

    match /users/{userId}/tasks/{taskId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/staffPlanner/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isRequestAdmin();
    }

    match /teams/{teamId}/members/{memberId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isRequestAdmin();
    }

    match /kpiDefinitions/{kpiId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isRequestAdmin();
    }

    match /matches/{matchId} {
      /**
       * Import / transakcje: get na nieistniejącym dokumencie musi przejść, inaczej permission-denied
       * zanim klient wykona set z team z pliku (merge zawodników — to samo dla players/{id}).
       */
      allow read: if request.auth != null && (
        isRequestAdmin() ||
        (
          !exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          !exists(/databases/$(database)/documents/matches/$(matchId))
        ) ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          (
            (
              !isPlayerRoleField(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '')) &&
              !exists(/databases/$(database)/documents/matches/$(matchId))
            ) ||
            teamIdInAllowedTeams(resource.data.get('teamId', ''), get(/databases/$(database)/documents/users/$(request.auth.uid)).data) ||
            teamIdInAllowedTeams(resource.data.get('team', ''), get(/databases/$(database)/documents/users/$(request.auth.uid)).data)
          )
        )
      );
      allow write: if request.auth != null &&
        (
          isRequestAdmin() ||
          authenticatedWithoutUserDocCanWriteMatch() ||
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            (
              teamIdInAllowedTeams(request.resource.data.get('teamId', ''), get(/databases/$(database)/documents/users/$(request.auth.uid)).data) ||
              teamIdInAllowedTeams(request.resource.data.get('team', ''), get(/databases/$(database)/documents/users/$(request.auth.uid)).data) ||
              staffWithNoTeamListCanCreateMatch()
            )
          )
        );
    }

    match /players_archive/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && !hasForbiddenPIIKeys(request.resource.data);
    }
    match /matches_archive/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && !hasForbiddenPIIKeys(request.resource.data);
    }
    match /gps_archive/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && !hasForbiddenPIIKeys(request.resource.data);
    }
    match /actions_archive/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && !hasForbiddenPIIKeys(request.resource.data);
    }
    match /teams_archive/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && !hasForbiddenPIIKeys(request.resource.data);
    }

    match /players/{playerId} {
      allow read: if request.auth != null && (
        isRequestAdmin() ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          (
            (
              isPlayerRoleField(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '')) &&
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('linkedPlayerId', '') == playerId
            ) ||
            (
              !isPlayerRoleField(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '')) &&
              (
                !exists(/databases/$(database)/documents/players/$(playerId)) ||
                teamsDataTouchesAllowed(resource.data)
              )
            )
          )
        )
      );
      allow create: if request.auth != null && (
        isRequestAdmin() ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          !isPlayerRoleField(requestUserRole()) &&
          teamsDataTouchesAllowed(request.resource.data)
        )
      );
      allow update: if request.auth != null && (
        isRequestAdmin() ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          !isPlayerRoleField(requestUserRole()) &&
          (
            teamsDataTouchesAllowed(request.resource.data) ||
            (
              teamsDataTouchesAllowed(resource.data) &&
              normalizedTeamsHasOnlySubset(resource.data, request.resource.data)
            )
          )
        )
      );
      allow delete: if request.auth != null && (
        isRequestAdmin() ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          !isPlayerRoleField(requestUserRole()) &&
          teamsDataTouchesAllowed(resource.data)
        )
      );
    }

    match /gps/{gpsId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && !hasForbiddenPIIKeys(request.resource.data);
      allow delete: if request.auth != null;
    }

    match /gps_norms/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /actions/{actionId} {
      allow read, write: if request.auth != null;
    }

    match /actions_packing/{actionId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /permission_tests/{document} {
      allow read, write: if request.auth != null;
    }

    match /pii_cleanup_backups/{document=**} {
      allow read, write: if false;
    }

    match /settings/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isRequestAdmin();
    }
  }
}
