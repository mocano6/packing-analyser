# --- Szybki start (lokalnie) ---
# npm run setup:local → tworzy .env.local z tego szablonu (jeśli jeszcze nie ma)
# Uzupełnij NEXT_PUBLIC_FIREBASE_* i sekcję Admin SDK poniżej, potem:
# npm run check:firebase-admin && npm run dev

# Klucze API Firebase (klient — Firebase Console → Project settings → Your apps → Web)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# Tryb środowiska
NODE_ENV=development

# Ustawienia aplikacji
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false
NEXT_PUBLIC_FORCE_OFFLINE_MODE=false
NEXT_PUBLIC_DEBUGGING_ENABLED=false

# App settings
NEXT_PUBLIC_STATIC_EXPORT="true"

# Optional: Firebase Database URL (if using Firebase Realtime Database)
# NEXT_PUBLIC_FIREBASE_DATABASE_URL="https://your-project-id.firebaseio.com"

# =============================================================================
# Firebase Admin SDK (Node / API routes Next.js)
# Wymagane do m.in.: weryfikacji tokenu, zapisu Firestore z serwera, importu meczu.
#
# Endpointy korzystające z Admin SDK (lista aktualizuj przy nowych route):
#   - POST /api/matches/save
#   - POST /api/matches/import-merge
#   - POST /api/delete-user-auth
#   - POST /api/admin-set-user-password
#   - POST /api/admin-remove-player-from-team
#   - POST /api/players-save
#   - POST /api/players-soft-delete
#   - POST /api/migrate-regain-loses
#
# Wybierz jedną opcję:
# =============================================================================

# Opcja A: ścieżka do JSON z Firebase Console → Project settings → Service accounts → Generate new private key
# Jeśli zapiszesz plik jako firebase-admin-service-account.json w katalogu głównym repo, Next.js wczyta go automatycznie
# (bez tej zmiennej). Plik jest w .gitignore — nie commituj.
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-admin-service-account.json

# Opcja B: cały JSON service account w jednej linii (CI / Vercel)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Opcja C: ten sam JSON w Base64 (wygodne gdy env nie lubi cudzysłowów)
# FIREBASE_SERVICE_ACCOUNT_KEY_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...

# Opcja D: standardowa zmienna Google — ścieżka absolutna do pliku JSON
# GOOGLE_APPLICATION_CREDENTIALS=/ścieżka/do/klucza.json
